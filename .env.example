APP_NAME=AIRNKAP
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO

# Provider Selection
EMBEDDING_PROVIDER=openai
LLM_PROVIDER=openai

# Database
DATABASE_URL=sqlite:///./data/sqlite/app.db
DATABASE_ECHO=false

# Auth / Security
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ALGORITHM=HS256

# App Security
TRUSTED_HOSTS=["localhost","127.0.0.1"]
CORS_ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["Authorization","Content-Type"]
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Redis / Celery
REDIS_URL=redis://:your-redis-password@127.0.0.1:6379/0
CELERY_BROKER_URL=redis://:your-redis-password@127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://:your-redis-password@127.0.0.1:6379/1
CELERY_INGESTION_QUEUE=document_ingestion
CELERY_INGESTION_MAX_RETRIES=3
CELERY_INGESTION_RETRY_DELAY_SECONDS=30

# Upload
UPLOAD_MAX_FILE_SIZE_MB=25
UPLOAD_ALLOWED_EXTENSIONS=["pdf","docx","txt","json","csv","xlsx"]
UPLOAD_ALLOWED_MIME_TYPES=["application/pdf","application/vnd.openxmlformats-officedocument.wordprocessingml.document","text/plain","application/json","text/csv","application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"]

# Chunking
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=120

# Embeddings
EMBEDDING_MODEL_NAME=text-embedding-3-large
EMBEDDING_MODEL_VERSION=v1
EMBEDDING_BATCH_SIZE=32
EMBEDDING_REQUEST_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=3

# Chat
CHAT_MODEL_NAME=gpt-4o-mini
CHAT_TEMPERATURE=0.1
CHAT_REQUEST_TIMEOUT_SECONDS=60
CHAT_MAX_RETRIES=3
CHAT_HISTORY_MESSAGES_LIMIT=8

# OpenAI
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=replace-with-your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# Pinecone
PINECONE_API_KEY=replace-with-your-key
PINECONE_INDEX_NAME=airnkap-docs
PINECONE_NAMESPACE=default
PINECONE_ENVIRONMENT=us-east-1
PINECONE_UPSERT_BATCH_SIZE=100
